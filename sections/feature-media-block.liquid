
<style>
  .fmb-section {
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
    background-color: {{ section.settings.section_bg_color }};
  }

  .fmb-section__title {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 30px;
    color: {{ section.settings.section_title_color }};
    font-family: inherit;
  }

  .fmb-container {
    margin: 0 auto;
    padding: 0 20px;
  }

  .fmb-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  /* ── Block Card ── */
  .fmb-block {
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18), 0 2px 8px rgba(0, 0, 0, 0.10);
    transition: transform 0.32s cubic-bezier(.22,.68,0,1.2), box-shadow 0.32s ease;
    background: #fff;
    cursor: pointer;
    position: relative;
  }

  .fmb-block:hover {
    transform: translateY(-6px) scale(1.015);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.22), 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  /* ── Media Wrapper ── */
  .fmb-block__media {
    position: relative;
    width: 100%;
    padding-top: {{ section.settings.media_aspect_ratio }}%;
    overflow: hidden;
    background: #e8e8e8;
  }

  .fmb-block__media img,
  .fmb-block__media video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .fmb-block:hover .fmb-block__media img,
  .fmb-block:hover .fmb-block__media video {
    transform: scale(1.04);
  }

  /* Video play badge */
  .fmb-block__play-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.85);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    pointer-events: none;
  }

  .fmb-block__play-badge svg {
    width: 16px;
    height: 16px;
    fill: #333;
  }

  /* Placeholder when no media */
  .fmb-block__placeholder {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #e0e0e0 0%, #c8c8c8 100%);
  }

  .fmb-block__placeholder svg {
    width: 48px;
    height: 48px;
    fill: #aaa;
  }

  /* ── Caption Area ── */
  .fmb-block__caption {
    padding: 14px 16px 16px;
    background-color: {{ section.settings.caption_bg_color }};
    text-align: center;
  }

  .fmb-block__heading {
    font-size: {{ section.settings.heading_font_size }}px;
    font-weight: 700;
    margin: 0 0 4px;
    color: {{ section.settings.heading_color }};
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .fmb-block__subtext {
    font-size: {{ section.settings.subtext_font_size }}px;
    margin: 0;
    color: {{ section.settings.subtext_color }};
    line-height: 1.4;
    opacity: 0.82;
  }

  /* ── Link overlay ── */
  .fmb-block__link-overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 899px) {
    .fmb-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ section.settings.grid_gap | divided_by: 1.4 | round }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .fmb-block__heading {
      font-size: {{ section.settings.heading_font_size | minus: 2 }}px;
    }
    .fmb-block__subtext {
      font-size: {{ section.settings.subtext_font_size | minus: 1 }}px;
    }
  }
</style>

<section class="fmb-section" id="section-{{ section.id }}">
  <div class="fmb-container">

    {% if section.settings.section_title != blank %}
      <h2 class="fmb-section__title">{{ section.settings.section_title }}</h2>
    {% endif %}

    <div class="fmb-grid">

      {% for block in section.blocks %}
        {% assign has_video = false %}
        {% if block.settings.video_url != blank or block.settings.video_file != blank %}
          {% assign has_video = true %}
        {% endif %}

        <div class="fmb-block" {{ block.shopify_attributes }}>

          {% comment %} Optional link overlay {% endcomment %}
          {% if block.settings.block_link != blank %}
            <a href="{{ block.settings.block_link }}" class="fmb-block__link-overlay" aria-label="{{ block.settings.heading }}"></a>
          {% endif %}

          {% comment %} ── Media ── {% endcomment %}
          <div class="fmb-block__media">

            {% if has_video %}
              {% comment %} Video: prefer uploaded file, fallback to URL {% endcomment %}
              {% if block.settings.video_file != blank %}
                <video
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  aria-label="{{ block.settings.heading | escape }}"
                >
                  <source src="{{ block.settings.video_file }}" type="video/mp4">
                </video>
              {% elsif block.settings.video_url != blank %}
                <video
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  aria-label="{{ block.settings.heading | escape }}"
                >
                  <source src="{{ block.settings.video_url }}" type="video/mp4">
                </video>
              {% endif %}

              {% if block.settings.show_video_badge %}
                <div class="fmb-block__play-badge" aria-hidden="true">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z"/></svg>
                </div>
              {% endif %}

            {% elsif block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  alt: block.settings.heading,
                  widths: '400, 600, 800',
                  sizes: '(max-width: 480px) calc(50vw - 20px), (max-width: 899px) calc(50vw - 24px), calc(25vw - 24px)'
              }}

            {% else %}
              <div class="fmb-block__placeholder" aria-hidden="true">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
              </div>
            {% endif %}

          </div>
          {% comment %} ── /Media ── {% endcomment %}

          {% comment %} ── Caption ── {% endcomment %}
          {% if block.settings.heading != blank or block.settings.subtext != blank %}
            <div class="fmb-block__caption">
              {% if block.settings.heading != blank %}
                <p class="fmb-block__heading">{{ block.settings.heading }}</p>
              {% endif %}
              {% if block.settings.subtext != blank %}
                <p class="fmb-block__subtext">{{ block.settings.subtext }}</p>
              {% endif %}
            </div>
          {% endif %}
          {% comment %} ── /Caption ── {% endcomment %}

        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Media Blocks",
  "tag": "section",
  "class": "featured-media-blocks",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Default"
    },
    {
      "type": "color",
      "id": "section_title_color",
      "label": "Section Title Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#f4f4f4"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap Between Cards (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card Border Radius (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "media_aspect_ratio",
      "label": "Media Aspect Ratio (%)",
      "info": "100 = 1:1 square, 75 = 4:3, 56 = 16:9",
      "min": 40,
      "max": 130,
      "step": 5,
      "default": 100
    },
    {
      "type": "header",
      "content": "Caption"
    },
    {
      "type": "color",
      "id": "caption_bg_color",
      "label": "Caption Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext Color",
      "default": "#555555"
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "label": "Subtext Font Size (px)",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 13
    }
  ],
  "blocks": [
    {
      "type": "media_block",
      "name": "Media Block",
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Used when no video is set."
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (MP4)",
          "info": "Enter a direct .mp4 URL. Leave blank to use an uploaded video file."
        },
        {
          "type": "text",
          "id": "video_file",
          "label": "Video File URL",
          "info": "Paste the CDN URL of a video uploaded to your Shopify Files."
        },
        {
          "type": "checkbox",
          "id": "show_video_badge",
          "label": "Show Video Badge",
          "default": true
        },
        {
          "type": "header",
          "content": "Caption"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Product Name"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext / Tag Line",
          "default": "Short description here"
        },
        {
          "type": "header",
          "content": "Link"
        },
        {
          "type": "url",
          "id": "block_link",
          "label": "Block Link",
          "info": "Makes the entire card clickable."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Media Blocks",
      "blocks": [
        {
          "type": "media_block",
          "settings": {
            "heading": "Kingston x Innokin",
            "subtext": "Plexus | Pod Juice Offer"
          }
        },
        {
          "type": "media_block",
          "settings": {
            "heading": "Pyne Click S 30K",
            "subtext": "2 Flavours in 1 | Cross-compatible"
          }
        },
        {
          "type": "media_block",
          "settings": {
            "heading": "Kingston Pod Juice",
            "subtext": "26 Flavours"
          }
        },
        {
          "type": "media_block",
          "settings": {
            "heading": "Hayati Pro Ultra+ 25K",
            "subtext": "20 Flavours"
          }
        }
      ]
    }
  ]
}
{% endschema %}
