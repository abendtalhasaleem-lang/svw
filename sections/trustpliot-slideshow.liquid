{% comment %}
  Trustpilot Reviews Slider Section
  - Per-rating star colours (1–5 each independently configurable)
  - Logo image picker in header (top-right)
{% endcomment %}

{%- comment -%}
  Build a CSS class → colour map for each rating level (1-5).
  Each rating gets its OWN filled-star colour; empty stars share one colour.
{%- endcomment -%}

<style>
  .tp-section {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
  }

  .tp-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Header ── */
  .tp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .tp-heading {
    font-size: {{ section.settings.heading_font_size }}px;
    font-weight: 600;
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.3;
  }

  /* Logo top-right */
  .tp-logo-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .tp-logo-wrap img {
    max-height: {{ section.settings.logo_max_height }}px;
    width: auto;
    display: block;
  }

  .tp-logo-placeholder {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 18px;
    font-weight: 700;
    color: #333;
  }

  .tp-logo-placeholder svg {
    width: 26px;
    height: 26px;
  }

  /* ── Slider ── */
  .tp-slider-outer {
    overflow: hidden;
    position: relative;
  }

  .tp-slider-track {
    display: flex;
    gap: 20px;
    transition: transform 0.4s ease;
    will-change: transform;
  }

  /* ── Card ── */
  .tp-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: 24px 22px 20px;
    flex: 0 0 calc(33.333% - 14px);
    min-width: calc(33.333% - 14px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }

  /* ── Stars ── */
  .tp-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 14px;
    flex-shrink: 0;
  }

  .tp-star {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .tp-star svg {
    width: 20px;
    height: 20px;
  }

  /* Empty star (shared colour) */
  .tp-star.empty {
    background-color: {{ section.settings.star_empty_color }};
  }

  /* Per-rating filled star colours */
  .tp-stars.rating-1 .tp-star.filled { background-color: {{ section.settings.star_color_1 }}; }
  .tp-stars.rating-2 .tp-star.filled { background-color: {{ section.settings.star_color_2 }}; }
  .tp-stars.rating-3 .tp-star.filled { background-color: {{ section.settings.star_color_3 }}; }
  .tp-stars.rating-4 .tp-star.filled { background-color: {{ section.settings.star_color_4 }}; }
  .tp-stars.rating-5 .tp-star.filled { background-color: {{ section.settings.star_color_5 }}; }

  /* ── Review text ── */
  .tp-review-title {
    font-size: 16px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 10px;
    line-height: 1.4;
  }

  .tp-review-body {
    font-size: 14px;
    color: {{ section.settings.text_color }};
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
    opacity: 0.85;
  }

  /* ── Author row ── */
  .tp-author-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20px;
    padding-top: 14px;
    border-top: 1px solid #f0f0f0;
  }

  .tp-author-name {
    font-size: 12px;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.03em;
    opacity: 0.7;
  }

  .tp-author-date {
    font-size: 12px;
    color: {{ section.settings.text_color }};
    opacity: 0.6;
  }

  /* ── Footer ── */
  .tp-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20px;
    gap: 12px;
    flex-wrap: wrap;
  }

  .tp-nav {
    display: flex;
    gap: 8px;
  }

  .tp-btn {
    width: 38px;
    height: 38px;
    border: 1px solid {{ section.settings.nav_btn_border_color }};
    background: {{ section.settings.nav_btn_bg }};
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s;
  }

  .tp-btn:hover {
    background: {{ section.settings.nav_btn_hover_bg }};
    border-color: {{ section.settings.nav_btn_hover_border }};
  }

  .tp-btn svg {
    width: 16px;
    height: 16px;
    stroke: {{ section.settings.nav_btn_icon_color }};
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Rating summary ── */
  .tp-summary {
    font-size: 15px;
    color: {{ section.settings.text_color }};
    opacity: 0.85;
  }

  .tp-summary strong {
    font-weight: 700;
  }

  .tp-summary a {
    color: {{ section.settings.text_color }};
    text-decoration: underline;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .tp-card {
      flex: 0 0 calc(50% - 10px);
      min-width: calc(50% - 10px);
    }
  }

  @media (max-width: 600px) {
    .tp-card {
      flex: 0 0 100%;
      min-width: 100%;
    }
    .tp-heading {
      font-size: {{ section.settings.heading_font_size | minus: 4 }}px;
    }
    .tp-summary {
      font-size: 12px;
    }
  }
</style>

<section class="tp-section" id="tp-section-{{ section.id }}">
  <div class="tp-container">

    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="tp-header">
      <h2 class="tp-heading">{{ section.settings.heading }}</h2>

      <div class="tp-logo-wrap">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ section.settings.logo_alt | escape }}"
            loading="lazy"
          >
        {%- else -%}
          {%- comment -%} Default Trustpilot-style fallback {%- endcomment -%}
          <div class="tp-logo-placeholder">
            <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color_5 }}" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            Trustpilot
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Slider ── {%- endcomment -%}
    <div class="tp-slider-outer" id="tp-outer-{{ section.id }}">
      <div class="tp-slider-track" id="tp-track-{{ section.id }}">

        {%- for block in section.blocks -%}
          {%- assign rating = block.settings.rating | plus: 0 -%}
          <div class="tp-card" {{ block.shopify_attributes }}>

            {%- comment -%} Stars — class "rating-N" drives the per-rating colour {%- endcomment -%}
            <div class="tp-stars rating-{{ rating }}" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  <span class="tp-star filled" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="#fff" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  </span>
                {%- else -%}
                  <span class="tp-star empty" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="#fff" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  </span>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if block.settings.review_title != blank -%}
              <p class="tp-review-title">{{ block.settings.review_title }}</p>
            {%- endif -%}

            {%- if block.settings.review_text != blank -%}
              <p class="tp-review-body">{{ block.settings.review_text }}</p>
            {%- endif -%}

            <div class="tp-author-row">
              <span class="tp-author-name">{{ block.settings.author_name }}</span>
              <span class="tp-author-date">{{ block.settings.review_date }}</span>
            </div>

          </div>
        {%- endfor -%}

      </div>
    </div>

    {%- comment -%} ── Footer ── {%- endcomment -%}
    <div class="tp-footer">
      <div class="tp-nav">
        <button class="tp-btn tp-prev" id="tp-prev-{{ section.id }}" aria-label="Previous reviews">
          <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="tp-btn tp-next" id="tp-next-{{ section.id }}" aria-label="Next reviews">
          <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <div class="tp-summary">
        Rated <strong>{{ section.settings.summary_score }}</strong> / {{ section.settings.summary_max }} based on
        {%- if section.settings.summary_url != blank -%}
          <a href="{{ section.settings.summary_url }}" target="_blank" rel="noopener">{{ section.settings.summary_review_text }}</a>
        {%- else -%}
          <span style="text-decoration:underline;">{{ section.settings.summary_review_text }}</span>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var outer     = document.getElementById('tp-outer-' + sectionId);
  var track     = document.getElementById('tp-track-' + sectionId);
  var prevBtn   = document.getElementById('tp-prev-' + sectionId);
  var nextBtn   = document.getElementById('tp-next-' + sectionId);
  var autoSlide = {{ section.settings.auto_slide | json }};
  var autoDelay = {{ section.settings.auto_slide_delay | times: 1000 }};

  if (!track || !outer) return;

  var currentIndex = 0;
  var autoTimer    = null;

  function getVisibleCount() {
    var w = outer.offsetWidth;
    if (w <= 600) return 1;
    if (w <= 900) return 2;
    return 3;
  }

  function getCardWidth() {
    var cards = track.querySelectorAll('.tp-card');
    if (!cards.length) return 0;
    var style = window.getComputedStyle(track);
    var gap   = parseFloat(style.gap) || 20;
    var vis   = getVisibleCount();
    return (outer.offsetWidth - gap * (vis - 1)) / vis;
  }

  function totalCards() {
    return track.querySelectorAll('.tp-card').length;
  }

  function maxIndex() {
    return Math.max(0, totalCards() - getVisibleCount());
  }

  function goTo(idx) {
    currentIndex = Math.max(0, Math.min(idx, maxIndex()));
    var style = window.getComputedStyle(track);
    var gap   = parseFloat(style.gap) || 20;
    var cardW = getCardWidth();
    track.style.transform = 'translateX(-' + (currentIndex * (cardW + gap)) + 'px)';
  }

  prevBtn && prevBtn.addEventListener('click', function() { resetAuto(); goTo(currentIndex - 1); });
  nextBtn && nextBtn.addEventListener('click', function() { resetAuto(); goTo(currentIndex + 1); });

  function startAuto() {
    if (!autoSlide) return;
    autoTimer = setInterval(function() {
      goTo(currentIndex >= maxIndex() ? 0 : currentIndex + 1);
    }, autoDelay);
  }

  function resetAuto() {
    if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
    startAuto();
  }

  window.addEventListener('resize', function() { goTo(currentIndex); });

  goTo(0);
  startAuto();
})();
</script>

