{{ 'section-scotland-deals.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings

  if s.section_bg_type == 'gradient'
    assign section_bg = 'radial-gradient(ellipse at top center, ' | append: s.section_gradient_start | append: ', ' | append: s.section_gradient_end | append: ' 75%)'
  else
    assign section_bg = s.section_bg_color
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
    background: {{ section_bg }};
  }

  #ScotlandDeals-{{ section.id }} {
    --sd-header-gap: {{ s.header_bottom_spacing }}px;
    --sd-header-gap-mobile: {{ s.header_bottom_spacing | times: 0.7 | round: 0 }}px;
    --sd-header-inner-gap: {{ s.header_inner_gap }}px;
    --sd-badge-size: {{ s.badge_font_size }}px;
    --sd-heading-size: {{ s.heading_font_size }}px;
    --sd-heading-size-mobile: {{ s.heading_font_size_mobile }}px;
    --sd-text-size: {{ s.text_font_size }}px;
    --sd-grid-gap: {{ s.grid_gap }}px;
    --sd-card-radius: {{ s.card_border_radius }}px;
    --sd-card-min-height: {% if s.card_min_height > 0 %}{{ s.card_min_height }}px{% else %}auto{% endif %};
    --sd-card-padding-y: {{ s.card_padding_vertical }}px;
    --sd-card-padding-x: {{ s.card_padding_horizontal }}px;
    --sd-card-padding-y-mobile: {{ s.card_padding_vertical | times: 0.78 | round: 0 }}px;
    --sd-card-padding-x-mobile: {{ s.card_padding_horizontal | times: 0.78 | round: 0 }}px;
    --sd-card-badge-size: {{ s.card_badge_font_size }}px;
    --sd-card-heading-size: {{ s.card_heading_font_size }}px;
    --sd-card-heading-size-mobile: {{ s.card_heading_font_size_mobile }}px;
    --sd-card-text-size: {{ s.card_text_font_size }}px;
    --sd-card-button-size: {{ s.card_button_font_size }}px;
    --sd-corner-icon-size: {{ s.corner_icon_size }}px;
    --sd-corner-icon-opacity: {{ s.corner_icon_opacity | divided_by: 100.0 }};
  }

  {%- if s.full_width -%}
    #ScotlandDeals-{{ section.id }} .scotland-deals__container {
      max-width: 100%;
      padding-left: {{ s.content_padding_horizontal }}px;
      padding-right: {{ s.content_padding_horizontal }}px;
    }
  {%- endif -%}

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 749px) {
    {%- if s.full_width -%}
      #ScotlandDeals-{{ section.id }} .scotland-deals__container {
        padding-left: {{ s.content_padding_horizontal | divided_by: 2 | at_least: 12 }}px;
        padding-right: {{ s.content_padding_horizontal | divided_by: 2 | at_least: 12 }}px;
      }
    {%- endif -%}
  }
{%- endstyle -%}

<section
  id="ScotlandDeals-{{ section.id }}"
  class="scotland-deals"
>
  <div class="scotland-deals__container{% unless s.full_width %} page-width{% endunless %}">
    <header class="scotland-deals__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if s.show_badge and s.badge_text != blank -%}
        <span
          class="scotland-deals__badge"
          style="background-color: {{ s.badge_bg_color }}; color: {{ s.badge_text_color }};"
        >
          {%- if s.badge_icon != blank -%}
            <span class="scotland-deals__badge-icon">
              {{
                s.badge_icon
                | image_url: width: 40
                | image_tag: loading: 'lazy', alt: ''
              }}
            </span>
          {%- endif -%}
          {{ s.badge_text | escape }}
        </span>
      {%- endif -%}

      {%- if s.heading_part_one != blank or s.heading_part_two != blank -%}
        <h2 class="scotland-deals__heading">
          {%- if s.heading_part_one != blank -%}
            <span class="scotland-deals__heading-part" style="color: {{ s.heading_color_one }};">
              {{- s.heading_part_one | escape -}}
            </span>
          {%- endif -%}
          {%- if s.heading_part_two != blank -%}
            <span class="scotland-deals__heading-part" style="color: {{ s.heading_color_two }};">
              {{- s.heading_part_two | escape -}}
            </span>
          {%- endif -%}
        </h2>
      {%- endif -%}

      {%- if s.text != blank -%}
        <div class="scotland-deals__text" style="color: {{ s.text_color }};">
          {{ s.text }}
        </div>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="scotland-deals__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'deal' -%}
            {% render 'scotland-deal-card', block: block, animation_index: forloop.index %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

