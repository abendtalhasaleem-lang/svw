{{ 'section-scotland-trade-cta.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_tag = section.settings.heading_tag | default: 'h2'

  if section.settings.background_type == 'gradient'
    assign panel_background = 'linear-gradient(' | append: section.settings.gradient_angle | append: 'deg, ' | append: section.settings.gradient_color_start | append: ' 0%, ' | append: section.settings.gradient_color_end | append: ' 100%)'
  else
    assign panel_background = section.settings.background_color
  endif

  assign stat_blocks = section.blocks | where: 'type', 'stat'
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.section_background_color }};
  }

  #ScotlandTradeCta-{{ section.id }} {
    --scotland-trade-cta-radius: {{ section.settings.panel_border_radius }}px;
    --scotland-trade-cta-panel-padding-y: {{ section.settings.panel_padding_vertical }}px;
    --scotland-trade-cta-panel-padding-x: {{ section.settings.panel_padding_horizontal }}px;
    --scotland-trade-cta-panel-padding-y-mobile: {{ section.settings.panel_padding_vertical | times: 0.7 | round: 0 }}px;
    --scotland-trade-cta-panel-padding-x-mobile: {{ section.settings.panel_padding_horizontal | times: 0.55 | round: 0 }}px;
    --scotland-trade-cta-layout-gap: {{ section.settings.layout_gap }}px;
    --scotland-trade-cta-layout-gap-mobile: {{ section.settings.layout_gap | times: 0.7 | round: 0 }}px;
    --scotland-trade-cta-content-gap: {{ section.settings.content_gap }}px;
    --scotland-trade-cta-heading-color: {{ section.settings.heading_color }};
    --scotland-trade-cta-heading-size: {{ section.settings.heading_font_size }}px;
    --scotland-trade-cta-heading-size-mobile: {{ section.settings.heading_font_size_mobile }}px;
    --scotland-trade-cta-heading-weight: {{ section.settings.heading_font_weight }};
    --scotland-trade-cta-text-color: {{ section.settings.text_color }};
    --scotland-trade-cta-text-size: {{ section.settings.text_font_size }}px;
    --scotland-trade-cta-text-size-mobile: {{ section.settings.text_font_size_mobile }}px;
    --scotland-trade-cta-text-weight: {{ section.settings.text_font_weight }};
    --scotland-trade-cta-buttons-top-spacing: {{ section.settings.buttons_top_spacing }}px;
    --scotland-trade-cta-button-gap: {{ section.settings.button_gap }}px;
    --scotland-trade-cta-button-min-height: {{ section.settings.button_min_height }}px;
    --scotland-trade-cta-button-radius: {{ section.settings.button_border_radius }}px;
    --scotland-trade-cta-button-font-size: {{ section.settings.button_font_size }}px;
    --scotland-trade-cta-button-font-weight: {{ section.settings.button_font_weight }};
    --scotland-trade-cta-primary-bg: {{ section.settings.primary_button_bg }};
    --scotland-trade-cta-primary-text: {{ section.settings.primary_button_text_color }};
    --scotland-trade-cta-secondary-bg: {{ section.settings.secondary_button_bg }};
    --scotland-trade-cta-secondary-text: {{ section.settings.secondary_button_text_color }};
    --scotland-trade-cta-secondary-border: {{ section.settings.secondary_button_border_color }};
    --scotland-trade-cta-stat-gap: {{ section.settings.stat_gap }}px;
    --scotland-trade-cta-stat-radius: {{ section.settings.stat_border_radius }}px;
    --scotland-trade-cta-stat-min-height: {{ section.settings.stat_min_height }}px;
    --scotland-trade-cta-stat-min-height-mobile: {{ section.settings.stat_min_height | times: 0.85 | round: 0 }}px;
    --scotland-trade-cta-stat-heading-color: {{ section.settings.stat_heading_color }};
    --scotland-trade-cta-stat-heading-size: {{ section.settings.stat_heading_font_size }}px;
    --scotland-trade-cta-stat-heading-size-mobile: {{ section.settings.stat_heading_font_size_mobile }}px;
    --scotland-trade-cta-stat-heading-weight: {{ section.settings.stat_heading_font_weight }};
    --scotland-trade-cta-stat-text-color: {{ section.settings.stat_text_color }};
    --scotland-trade-cta-stat-text-size: {{ section.settings.stat_text_font_size }}px;
    --scotland-trade-cta-stat-text-weight: {{ section.settings.stat_text_font_weight }};
    --scotland-trade-cta-stat-bg: {{ section.settings.stat_background_color }};
  }

  #ScotlandTradeCta-{{ section.id }} .scotland-trade-cta__panel {
    background: {{ panel_background }};
  }

  {%- if section.settings.full_width -%}
    #ScotlandTradeCta-{{ section.id }} .scotland-trade-cta__container {
      max-width: 100%;
      padding-left: {{ section.settings.content_padding_horizontal }}px;
      padding-right: {{ section.settings.content_padding_horizontal }}px;
    }
  {%- endif -%}

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 749px) {
    {%- if section.settings.full_width -%}
      #ScotlandTradeCta-{{ section.id }} .scotland-trade-cta__container {
        padding-left: {{ section.settings.content_padding_horizontal | divided_by: 2 | at_least: 12 }}px;
        padding-right: {{ section.settings.content_padding_horizontal | divided_by: 2 | at_least: 12 }}px;
      }
    {%- endif -%}
  }
{%- endstyle -%}

<section class="scotland-trade-cta" id="ScotlandTradeCta-{{ section.id }}">
  <div class="scotland-trade-cta__container{% unless section.settings.full_width %} page-width{% endunless %}">
    <div class="scotland-trade-cta__panel">
      <div class="scotland-trade-cta__layout">
        <div class="scotland-trade-cta__content">
          {%- if section.settings.heading != blank -%}
            <{{ heading_tag }} class="scotland-trade-cta__heading">
              {{ section.settings.heading | escape }}
            </{{ heading_tag }}>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="scotland-trade-cta__text rte">
              {{ section.settings.text }}
            </div>
          {%- endif -%}

          {%- if section.settings.show_primary_button or section.settings.show_secondary_button -%}
            <div class="scotland-trade-cta__buttons">
              {%- if section.settings.show_primary_button and section.settings.primary_button_label != blank -%}
                {%- if section.settings.primary_button_link != blank -%}
                  <a href="{{ section.settings.primary_button_link }}" class="scotland-trade-cta__button scotland-trade-cta__button--primary">
                    <span>{{ section.settings.primary_button_label | escape }}</span>
                    {%- if section.settings.show_primary_button_arrow -%}
                      <span class="scotland-trade-cta__button-icon" aria-hidden="true">
                        {{- 'icon-arrow.svg' | inline_asset_content -}}
                      </span>
                    {%- endif -%}
                  </a>
                {%- else -%}
                  <span class="scotland-trade-cta__button scotland-trade-cta__button--primary">
                    <span>{{ section.settings.primary_button_label | escape }}</span>
                    {%- if section.settings.show_primary_button_arrow -%}
                      <span class="scotland-trade-cta__button-icon" aria-hidden="true">
                        {{- 'icon-arrow.svg' | inline_asset_content -}}
                      </span>
                    {%- endif -%}
                  </span>
                {%- endif -%}
              {%- endif -%}

              {%- if section.settings.show_secondary_button and section.settings.secondary_button_label != blank -%}
                {%- if section.settings.secondary_button_link != blank -%}
                  <a href="{{ section.settings.secondary_button_link }}" class="scotland-trade-cta__button scotland-trade-cta__button--secondary">
                    {{ section.settings.secondary_button_label | escape }}
                  </a>
                {%- else -%}
                  <span class="scotland-trade-cta__button scotland-trade-cta__button--secondary">
                    {{ section.settings.secondary_button_label | escape }}
                  </span>
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if stat_blocks.size > 0 -%}
          <div class="scotland-trade-cta__stats">
            {%- for block in stat_blocks -%}
              <div class="scotland-trade-cta__stat" {{ block.shopify_attributes }}>
                {%- if block.settings.stat_heading != blank -%}
                  <p class="scotland-trade-cta__stat-heading">{{ block.settings.stat_heading | escape }}</p>
                {%- endif -%}
                {%- if block.settings.stat_text != blank -%}
                  <p class="scotland-trade-cta__stat-text">{{ block.settings.stat_text | escape }}</p>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Scotland trade CTA",
  "tag": "section",
  "class": "section section-scotland-trade-cta",
  "max_blocks": 4,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Exclusive Trade Pricing"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Register for a trade account to access wholesale prices, bulk discounts, and exclusive offers. Join hundreds of UK retailers who trust OV Distribution.</p>"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 20,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Heading font size (desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 18,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Heading font size (mobile)",
      "default": 28
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra bold" }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "min": 12,
      "max": 24,
