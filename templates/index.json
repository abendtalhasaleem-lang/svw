        "faq_item_WhCK9G": {
          "type": "faq_item",
          "settings": {
            "question": "Where can I buy vape UK products safely online?",
            "answer": "<p>You can buy vape UK products safely online right here at Select Vape Club. We are a fully compliant UK retailer, meaning every product we sell meets MHRA standards.</p>"
          }
        },
        "faq_item_ydPj8N": {
          "type": "faq_item",
          "settings": {
            "question": "Are you the cheapest vape shop online UK?",
            "answer": "<p>We work hard to offer the lowest prices on all leading vape brands. Our price-match guarantee means if you find a lower price elsewhere, we'll match it.</p>"
          }
        },
        "faq_item_4RcAED": {
          "type": "faq_item",
          "settings": {
            "question": "How fast is delivery from your UK vape shop?",
            "answer": "<p>We offer free next-day delivery on all orders placed before 3pm Monday to Friday. Weekend orders are dispatched on Monday.</p>"
          }
        },
        "faq_item_VPnG7g": {
          "type": "faq_item",
          "settings": {
            "question": "Do I need to verify my age to buy vape UK products?",
            "answer": "<p>Yes. UK law requires all customers to be 18 or over to purchase vape products. We use a secure, automated age verification system at checkout.</p>"
          }
        }
      },
