          "type": "faq_item",
          "settings": {
            "question": "What is the best vape shop online UK?",
            "answer": "<p>Select Vape Club is consistently rated as one of the best vape shops online UK has to offer, with over 355 verified 5-star Trustpilot reviews, free next-day delivery, and one of the widest product ranges in Britain.</p>"
          }
