{% comment %}
  Renders Scotland delivery timer block.

  Accepts:
  - block: {Object}
{% endcomment %}

{%- liquid
  assign cutoff_time = block.settings.cutoff_time | default: '17:00'
  assign delivery_days = block.settings.delivery_days | default: 1
  assign operating_days = ''

  if block.settings.deliver_sunday
    assign operating_days = '0'
  endif
  if block.settings.deliver_monday
    if operating_days != blank
      assign operating_days = operating_days | append: ',1'
    else
      assign operating_days = '1'
    endif
  endif
  if block.settings.deliver_tuesday
    if operating_days != blank
      assign operating_days = operating_days | append: ',2'
    else
      assign operating_days = '2'
    endif
  endif
  if block.settings.deliver_wednesday
    if operating_days != blank
      assign operating_days = operating_days | append: ',3'
    else
      assign operating_days = '3'
    endif
  endif
  if block.settings.deliver_thursday
    if operating_days != blank
      assign operating_days = operating_days | append: ',4'
    else
      assign operating_days = '4'
    endif
  endif
  if block.settings.deliver_friday
    if operating_days != blank
      assign operating_days = operating_days | append: ',5'
    else
      assign operating_days = '5'
    endif
  endif
  if block.settings.deliver_saturday
    if operating_days != blank
      assign operating_days = operating_days | append: ',6'
    else
      assign operating_days = '6'
    endif
  endif

  if operating_days == blank
    assign operating_days = '1,2,3,4,5'
  endif
-%}

{{ 'component-scotland-delivery-timer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'scotland-delivery-timer.js' | asset_url }}" defer="defer"></script>

<div
  class="scotland-delivery-timer"
  {{ block.shopify_attributes }}
  data-initialized="false"
  data-cutoff-time="{{ cutoff_time | escape }}"
  data-delivery-days="{{ delivery_days }}"
  data-operating-days="{{ operating_days }}"
  data-show-date-parentheses="{{ block.settings.show_date_in_parentheses }}"
  style="
    --scotland-delivery-icon-size: {{ block.settings.icon_size }}px;
    --scotland-delivery-icon: {{ block.settings.icon_color }};
    --scotland-delivery-text: {{ block.settings.text_color }};
    --scotland-delivery-highlight: {{ block.settings.highlight_color }};
    --scotland-delivery-date-suffix: {{ block.settings.date_suffix_color }};
    --scotland-delivery-border: {{ block.settings.border_color }};
    --scotland-delivery-bg: {{ block.settings.background_color }};
  "
>
  <div class="scotland-delivery-timer__row">
    <span class="scotland-delivery-timer__icon" aria-hidden="true">
      {%- if block.settings.icon_1_upload != blank -%}
        {{
          block.settings.icon_1_upload
          | image_url: width: 60
          | image_tag:
            loading: 'lazy',
            widths: '30, 60',
            sizes: '30px',
            class: 'scotland-delivery-timer__icon-img',
            alt: ''
        }}
      {%- else -%}
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 8V12L14.5 14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      {%- endif -%}
    </span>
    <div class="scotland-delivery-timer__text">
      {%- if block.settings.text_1 != blank -%}
        <span class="scotland-delivery-timer__label">{{ block.settings.text_1 | escape }}</span>
      {%- endif -%}
      <span class="scotland-delivery-timer__highlight" data-delivery-countdown>Calculating...</span>
    </div>
  </div>

  <div class="scotland-delivery-timer__row">
    <span class="scotland-delivery-timer__icon" aria-hidden="true">
      {%- if block.settings.icon_2_upload != blank -%}
        {{
          block.settings.icon_2_upload
          | image_url: width: 60
          | image_tag:
            loading: 'lazy',
            widths: '30, 60',
            sizes: '30px',
            class: 'scotland-delivery-timer__icon-img',
            alt: ''
        }}
      {%- else -%}
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 7H15V17H3V7Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M15 10H18L21 13V17H15V10Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <circle cx="7" cy="17" r="1.5" fill="currentColor"/>
          <circle cx="18" cy="17" r="1.5" fill="currentColor"/>
        </svg>
      {%- endif -%}
    </span>
    <div class="scotland-delivery-timer__text">
      {%- if block.settings.text_2 != blank -%}
        <span class="scotland-delivery-timer__label">{{ block.settings.text_2 | escape }}</span>
      {%- endif -%}
      <span class="scotland-delivery-timer__date-label" data-delivery-date-label>Calculating...</span>
      <span class="scotland-delivery-timer__date-suffix" data-delivery-date-suffix hidden></span>
    </div>
  </div>
</div>
