{% comment %}
  Scotland header desktop mega menu — hover to open, click parent link to navigate.
{% endcomment %}

<nav class="scotland-header__inline-menu header__inline-menu">
  <ul class="scotland-header__menu-list list-menu list-menu--inline" role="list">
    {%- for link in section.settings.menu.links -%}
      <li class="scotland-header__menu-item-wrap">
        {%- liquid
          assign menu_active = false
          if link.current
            assign menu_active = true
          elsif link.url == routes.root_url and request.page_type == 'index'
            assign menu_active = true
          elsif link.child_active
            assign menu_active = true
          endif

          assign mega_collection = nil
          if link.type == 'collection_link' and link.object != blank
            assign mega_collection = link.object
          elsif link.type == 'catalog_link' or link.type == 'collections_link'
            assign mega_collection = collections.all
          endif

          if mega_collection == blank and link.url contains '/collections/'
            assign mega_collection_handle = link.url | split: '/collections/' | last | split: '?' | first | split: '/' | first
            if collections[mega_collection_handle] != blank
              assign mega_collection = collections[mega_collection_handle]
            endif
          endif

          if mega_collection == blank
            for childlink in link.links
              if childlink.type == 'collection_link' and childlink.object != blank
                assign mega_collection = childlink.object
                break
              endif
            endfor
          endif

          assign mega_menu_cols = 6
          assign mega_product_count = 0
          if section.settings.mega_menu_show_products and mega_collection != blank
            assign mega_product_count = section.settings.mega_menu_product_count | plus: 0
            assign mega_menu_cols = 6 | minus: mega_product_count
          endif
        -%}
        {%- if link.links != blank -%}
          <div class="scotland-header__menu-flyout mega-menu scotland-header__menu-flyout--enhanced">
            <a
              id="ScotlandHeaderMenu-{{ link.handle }}"
              href="{{ link.url }}"
              class="scotland-header__menu-link header__menu-item list-menu__item link focus-inset{% if menu_active %} scotland-header__menu-link--active{% endif %}"
              {% if link.current %}
                aria-current="page"
              {% endif %}
            >
              <span class="scotland-header__menu-link-text">{{ link.title | escape }}</span>
              <span class="scotland-header__menu-caret svg-wrapper" aria-hidden="true">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </a>
            <div
              id="ScotlandMegaMenu-Content-{{ section.id }}-{{ forloop.index }}"
              class="mega-menu__content color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup scotland-header__mega-content scotland-header__mega-content--enhanced"
              tabindex="-1"
            >
              <div class="scotland-header__mega-grid{% unless section.settings.menu_full_width %} page-width{% endunless %}{% if mega_product_count > 0 %} scotland-header__mega-grid--with-products scotland-header__mega-grid--products-{{ mega_product_count }}{% endif %}">
                {%- for childlink in link.links limit: mega_menu_cols -%}
                  <div class="scotland-header__mega-column">
                    <a
                      href="{{ childlink.url }}"
                      class="scotland-header__mega-column-heading link{% if childlink.current %} scotland-header__mega-column-heading--active{% endif %}"
                      {% if childlink.current %}
                        aria-current="page"
                      {% endif %}
                    >
                      {{ childlink.title | escape }}
                    </a>
                    {%- if childlink.links != blank -%}
                      <ul class="scotland-header__mega-column-links list-unstyled" role="list">
                        {%- for grandchildlink in childlink.links -%}
                          <li>
                            <a
                              href="{{ grandchildlink.url }}"
                              class="scotland-header__mega-column-link link{% if grandchildlink.current %} scotland-header__mega-column-link--active{% endif %}"
                              {% if grandchildlink.current %}
                                aria-current="page"
                              {% endif %}
                            >
                              {{ grandchildlink.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                {%- endfor -%}

                {%- if mega_product_count > 0 and mega_collection != blank -%}
                  {%- for product in mega_collection.products limit: mega_product_count -%}
                    <div class="scotland-header__mega-column scotland-header__mega-column--product">
                      {% render 'scotland-header-mega-product', product: product, lazy_load: true %}
                    </div>
                  {%- endfor -%}
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- else -%}
          <a
            id="ScotlandHeaderMenu-{{ link.handle }}"
            href="{{ link.url }}"
            class="scotland-header__menu-link header__menu-item list-menu__item link focus-inset{% if menu_active %} scotland-header__menu-link--active{% endif %}"
            {% if link.current %}
              aria-current="page"
            {% endif %}
          >
            <span class="scotland-header__menu-link-text">{{ link.title | escape }}</span>
          </a>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>
