<div class="curlear-collapsible">
  {% if row_1_title != blank %}
    <details class="curlear-collapsible__row" {% if open_first_row %}open{% endif %}>
      <summary class="curlear-collapsible__summary">
        <span class="curlear-collapsible__summary-left">{{ row_1_title | escape }}</span>
        <span class="curlear-collapsible__caret{% if caret_icon != blank %} curlear-collapsible__caret--image{% endif %}">
          {%- if caret_icon != blank -%}
            <img
              src="{{ caret_icon | image_url: width: 64 }}"
              alt=""
              width="20"
              height="20"
              loading="lazy"
              decoding="async"
            >
          {%- endif -%}
        </span>
      </summary>
      <div class="curlear-collapsible__content-wrap">
        <div class="curlear-collapsible__content rte">{{ row_1_content }}</div>
      </div>
    </details>
  {% endif %}
