<div class="curlear-collapsible">
  {% if row_1_title != blank %}
    <details class="curlear-collapsible__row" {% if open_first_row %}open{% endif %}>
      <summary class="curlear-collapsible__summary">
        <span class="curlear-collapsible__summary-left">{{ row_1_title | escape }}</span>
        <span class="curlear-collapsible__caret{% if caret_icon != blank %} curlear-collapsible__caret--image{% endif %}">
          {%- if caret_icon != blank -%}
            <img
              src="{{ caret_icon | image_url: width: 64 }}"
              alt=""
              width="20"
              height="20"
              loading="lazy"
              decoding="async"
            >
          {%- endif -%}
        </span>
      </summary>
      <div class="curlear-collapsible__content-wrap">
        <div class="curlear-collapsible__content rte">{{ row_1_content }}</div>
      </div>
    </details>
  {% endif %}
  {% if row_2_title != blank %}
    <details class="curlear-collapsible__row">
      <summary class="curlear-collapsible__summary">
        <span class="curlear-collapsible__summary-left">{{ row_2_title | escape }}</span>
        <span class="curlear-collapsible__caret{% if caret_icon != blank %} curlear-collapsible__caret--image{% endif %}">
          {%- if caret_icon != blank -%}
            <img
              src="{{ caret_icon | image_url: width: 64 }}"
              alt=""
              width="20"
              height="20"
              loading="lazy"
              decoding="async"
            >
          {%- endif -%}
        </span>
      </summary>
      <div class="curlear-collapsible__content-wrap">
        <div class="curlear-collapsible__content rte">{{ row_2_content }}</div>
      </div>
    </details>
  {% endif %}
  {% if row_3_title != blank %}
    <details class="curlear-collapsible__row">
      <summary class="curlear-collapsible__summary">
        <span class="curlear-collapsible__summary-left">{{ row_3_title | escape }}</span>
        <span class="curlear-collapsible__caret{% if caret_icon != blank %} curlear-collapsible__caret--image{% endif %}">
          {%- if caret_icon != blank -%}
            <img
              src="{{ caret_icon | image_url: width: 64 }}"
              alt=""
              width="20"
              height="20"
              loading="lazy"
              decoding="async"
            >
          {%- endif -%}
        </span>
      </summary>
      <div class="curlear-collapsible__content-wrap">
        <div class="curlear-collapsible__content rte">{{ row_3_content }}</div>
      </div>
    </details>
  {% endif %}
  {% if row_4_title != blank %}
    <details class="curlear-collapsible__row">
      <summary class="curlear-collapsible__summary">
        <span class="curlear-collapsible__summary-left">{{ row_4_title | escape }}</span>
        <span class="curlear-collapsible__caret{% if caret_icon != blank %} curlear-collapsible__caret--image{% endif %}">
          {%- if caret_icon != blank -%}
            <img
              src="{{ caret_icon | image_url: width: 64 }}"
              alt=""
              width="20"
              height="20"
              loading="lazy"
              decoding="async"
            >
          {%- endif -%}
        </span>
      </summary>
      <div class="curlear-collapsible__content-wrap">
        <div class="curlear-collapsible__content rte">{{ row_4_content }}</div>
      </div>
    </details>
  {% endif %}
</div>
<style>
    
.curlear-collapsible {
  margin: 2.4rem 0;
  border-top: 1px solid #d9d9d9;
  border-bottom: 1px solid #d9d9d9;
}

.curlear-collapsible__row {
  border-top: 1px solid #d9d9d9;
  padding: 0 20px 0px 0px;
}

.curlear-collapsible__row:first-child {
  border-top: 0;
}

.curlear-collapsible__caret--image::before {
  content: none;
}

.curlear-collapsible__caret--image img {
  display: block;
  width: 2rem;
  height: 2rem;
  object-fit: contain;
  transition: transform 0.25s ease;
}

.curlear-collapsible__row[open] .curlear-collapsible__caret--image img {
  transform: rotate(180deg);
}

.curlear-collapsible__summary {
  list-style: none;
  cursor: pointer;
  padding: 1.4rem 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  font-size: 2rem;
  text-transform: uppercase;
}

.curlear-collapsible__summary::-webkit-details-marker {
  display: none;
}

.curlear-collapsible__summary-left {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  font-weight: 700;
  color: black;
}

.curlear-collapsible__icon {
  font-size: 1.4rem;
}

.curlear-collapsible__caret::before {
  font-size: 2rem;
  line-height: 1;
  display: inline-block;
  transition: transform 0.25s ease;
}

.curlear-collapsible__row[open] .curlear-collapsible__caret::before {
  content: '-';
}

.curlear-collapsible__row[open] .curlear-collapsible__caret--image::before {
  content: none;
}

.curlear-collapsible__content-wrap {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.28s ease;
}

.curlear-collapsible__row[open] .curlear-collapsible__content-wrap {
  grid-template-rows: 1fr;
}

.curlear-collapsible__content {
  overflow: hidden;
  padding: 0 0 1.4rem;
  opacity: 0;
  transform: translateY(-0.6rem);
  transition: opacity 0.28s ease, transform 0.28s ease;
}

.curlear-collapsible__row[open] .curlear-collapsible__content {
  opacity: 1;
  transform: translateY(0);
}
@media screen and (max-width: 749px) {
  .curlear-collapsible__summary-left {
    font-size: 15px;
  }
}
</style>