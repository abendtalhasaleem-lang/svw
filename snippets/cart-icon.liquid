{% comment %}
  Renders the cart icon from theme settings or default SVG icons.

  Accepts:
  - wrapper_class: {String} Optional class on the image when using a custom icon.
{% endcomment %}

{%- liquid
  assign icon_wrapper_class = wrapper_class | default: 'cart-icon-image'
-%}

{%- if settings.cart_icon_image != blank -%}
  {{
    settings.cart_icon_image
    | image_url: width: 120
    | image_tag:
      loading: 'lazy',
      widths: '40, 80, 120',
      sizes: '40px',
      class: icon_wrapper_class,
      alt: ''
  }}
{%- else -%}
  <span class="svg-wrapper">
    {%- if cart == empty -%}
      {{ 'icon-cart-empty.svg' | inline_asset_content }}
    {%- else -%}
      {{ 'icon-cart.svg' | inline_asset_content }}
    {%- endif -%}
  </span>
{%- endif -%}
